# Copy this file to `.env` and fill in your key. `.env` is gitignored — never commit it.
# Keystone runs fully offline/deterministic without a key; the key only activates
# the live Claude semantic layer (integrity summary, reviewer critique, hypotheses).
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx
# Locked Claude model for the semantic reasoning layer (claude-sonnet-5 recommended).
KEYSTONE_MODEL=claude-sonnet-5
